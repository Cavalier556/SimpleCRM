{%extends 'base.html'%}
{% block content %}

{% if pendientes %}
<aside class="fixed z-50 flex items-center justify-center px-5 py-3 bg-green-200 rounded-lg bottom-4 right-4">
    <span class="text-lg font-medium">
        Se encontraron {{ pendientes | length}} tareas pendientes
    </span>
    <button onClick="return this.parentNode.remove()" class="p-1 ml-3 rounded bg-white/20 hover:bg-white/10">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
            <path fillRule="evenodd"
                d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z"
                clipRule="evenodd" />
        </svg>
    </button>
</aside>
{% endif %}

<div class="flex flex-row justify-between items-center mb-8">
    <h1 class="text-3xl font-semibold text-[#758bfd]">
        Empresas
    </h1>
    <button onclick="toggleSidebar()" class="bg-[#ff8600] cursor-pointer text-white rounded-sm h-full py-2 px-4">Nueva
        empresa</button>
</div>
<div class="w-full bg-white border border-gray-200 rounded-lg shadow-xs font-sans">
    <div class="flex items-center justify-between p-3 border-b bg-slate-50 border-gray-100">
        <div class="relative w-128">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3">
                <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
            </span>
            <input type="text" name="nombre" hx-get="/" hx-headers='{"X-CSRFToken": "{{ csrf_token }}"}'
                hx-trigger="keyup delay:200ms changed" hx-select="#search_results" hx-target="#search_results"
                class="w-full py-1.5 pl-10 bg-white pr-4 text-sm border border-gray-200 rounded-md focus:outline-none focus:ring-1 focus:ring-teal-500"
                placeholder="Buscar empresas">
        </div>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse" id="search_results">
            <thead class="bg-slate-50 border-b border-gray-200">
                <tr class="text-[11px] font-bold text-gray-600 uppercase tracking-wider">
                    <th class="p-3 border-r border-gray-200 flex items-center justify-between">EMPRESA</th>
                    <th class="p-3 border-r border-gray-200">
                        <div class="flex items-center space-x-1">
                            <span>CONTACTOS</span>
                        </div>
                    </th>
                    <th class="p-3 border-r border-gray-200">FECHA DE CREACION</th>
                    <th class="p-3 border-r border-gray-200">TELEFONO</th>
                    <th class="p-3">DIRECCION</th>
                </tr>
            </thead>
            <tbody class="text-sm text-gray-700">
                {% for empresa in empresas %}
                <tr class="border-b border-gray-100 hover:bg-gray-50 transition-colors">
                    <td class="p-3 border-r border-gray-100">
                        <div class="flex items-center space-x-2">
                            <div class="flex flex-col">
                                <a class="text-[#758bfd] font-semibold hover:underline cursor-pointer"
                                    hx-get="/api/empresa/{{empresa.id}}/" onclick="toggleEditSidebar()"
                                    hx-headers='{"X-CSRFToken": "{{ csrf_token }}"}' hx-target="#empresa-detalles">
                                    {{ empresa.nombre }}
                                    <span class="text-gray-400 font-semibold">
                                        {{ empresa.rubro }}</span></a>
                                <span>{{ empresa.ruc }}</span>
                            </div>
                        </div>
                    </td>

                    <td class="p-3 border-r border-gray-100 bg-blue-50/20">
                        <a class="underline cursor-pointer" href="/contactos/?nombre={{empresa.nombre}}">
                            Ver Contactos
                        </a>
                    </td>
                    <td class="p-3 border-r border-gray-100">{{ empresa.fecha_creacion }}</td>
                    <td class="p-3 border-r border-gray-100">
                        +{{ empresa.telefono|slice:":2" }} {{ empresa.telefono|slice:"2:" }}</td>
                    <td class="p-3 truncate uppercase">{{ empresa.direccion }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>


<div id="sidebar-overlay"
    class="fixed inset-0 bg-gray-900/50 backdrop-blur-sm z-40 hidden transition-opacity opacity-0"></div>

<aside id="sidebar"
    class="fixed top-0 left-0 z-50 h-screen w-80 md:w-xl bg-white shadow-2xl transform -translate-x-full transition-transform duration-300 ease-in-out">
    <form class="p-6 h-full flex flex-col" action="/" method="POST">

        <div class="flex items-center justify-between mb-8">
            <h2 class="text-xl font-semibold text-[#758bfd]">
                Nueva Empresa
            </h2>
            <div onclick="toggleSidebar()" class="p-2 rounded-md hover:bg-gray-100 text-gray-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </div>
        </div>

        <div class="space-y-4 flex-grow overflow-y-scroll -mx-2 px-2">
            {% csrf_token %}
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">RUC</label>
                <div class="flex flex-row gap-2">
                    <input type="text" name="ruc" id="ruc_input"
                        class="w-full py-1.5 bg-white px-4 text-sm border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                        placeholder="RUC" maxlength="11" minlength="11" required>
                    <a class="bg-[#ff8600] text-white rounded-sm w-full inline-block py-2 px-4 cursor-pointer transition-opacity duration-200"
                        id="btnSUNAT" onclick="buscarSUNAT()">Buscar en
                        SUNAT</a>
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Razón Social</label>
                <input type="text" name="nombre" id="nombre_input"
                    class="w-full py-1.5 bg-white px-4 text-sm border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="Razón Social" required>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Dirección</label>
                <input type="text" name="direccion" id="direccion_input"
                    class="w-full py-1.5 bg-white px-4 text-sm border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="Dirección de la empresa">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Rubro</label>
                <input type="text" name="rubro" id="rubro_input"
                    class="w-full py-1.5 bg-white px-4 text-sm border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="Rubro del negocio">
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Telefono</label>
                <input type="text" name="telefono" id="telefono_input"
                    class="w-full py-1.5 bg-white px-4 text-sm border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500"
                    placeholder="Telefono de contacto" value="51">
            </div>
        </div>

        <div class="pt-6 border-t flex gap-3">
            <div onclick="toggleSidebar()"
                class="flex-1 px-4 py-2 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 cursor-pointer text-center">
                Cancelar</div>
            <button class="flex-1 px-4 py-2 bg-[#ff8600] text-white rounded-md cursor-pointer"
                type="submit">Guardar</button>
        </div>
    </form>

</aside>


<aside id="edit-sidebar"
    class="fixed top-0 right-0 z-50 h-screen w-80 md:w-xl bg-white shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out border-l border-gray-200">
    <div class="p-6 h-full flex flex-col">

        <div class="flex items-center justify-between mb-8">
            <div>
                <h2 class="text-xl font-semibold text-[#758bfd]">Editar Empresa</h2>
                <p class="text-sm text-gray-500">Actualizar información de la empresa</p>
            </div>
            <button onclick="toggleEditSidebar()" class="p-2 rounded-md hover:bg-gray-100 text-gray-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>
        <div id="empresa-detalles">

        </div>

        <div class="pt-6 flex flex-col gap-2">
            <button onclick="toggleEditSidebar()"
                class="w-full px-4 py-2 text-gray-600 hover:text-gray-800 text-sm">Cancelar</button>
        </div>
    </div>
</aside>


<script>
    async function buscarSUNAT() {
        const ruc_a_buscar = document.getElementById('ruc_input').value;
        const btn = document.getElementById('btnSUNAT');

        btn.innerText = "Buscando...";
        btn.style.pointerEvents = "none";
        btn.classList.add('opacity-50', 'cursor-not-allowed');

        try {
            const response = await fetch(`/api/sunat/${ruc_a_buscar}/`);
            if (!response.ok) {
                throw new Error('Network response was not ok');
            }
            const data = await response.json();
            document.getElementById('nombre_input').value = data.nombre;
            document.getElementById('direccion_input').value = data.direccion;

        } catch (error) {
            console.error('Error:', error);
            alert("No se pudo encontrar el RUC.");

        } finally {

            btn.innerText = "Buscar en SUNAT";
            btn.style.pointerEvents = "auto";
            btn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
    }

    function toggleSidebar() {
        const sidebar = document.getElementById('sidebar');
        const overlay = document.getElementById('sidebar-overlay');

        sidebar.classList.toggle('-translate-x-full');
        toggleOverlay(overlay);
    }


    function toggleEditSidebar() {
        const sidebar = document.getElementById('edit-sidebar');
        const overlay = document.getElementById('sidebar-overlay');

        sidebar.classList.toggle('translate-x-full');
        toggleOverlay(overlay);
    }

    function toggleOverlay(overlay) {
        if (overlay.classList.contains('hidden')) {
            overlay.classList.remove('hidden');
            setTimeout(() => overlay.classList.replace('opacity-0', 'opacity-100'), 10);
        } else {
            overlay.classList.replace('opacity-100', 'opacity-0');
            setTimeout(() => overlay.classList.add('hidden'), 300);
        }
    }

    document.getElementById('sidebar-overlay').addEventListener('click', () => {
        const sidebar = document.getElementById('sidebar');
        const editSidebar = document.getElementById('edit-sidebar');

        if (!sidebar.classList.contains('-translate-x-full')) toggleSidebar();
        if (!editSidebar.classList.contains('translate-x-full')) toggleEditSidebar();
    });
</script>

{% endblock %}