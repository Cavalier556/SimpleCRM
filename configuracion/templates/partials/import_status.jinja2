<div id="import-status" 
     {% if state != 'SUCCESS' and state != 'FAILURE' %}
     hx-get="{% url 'check_task_status' task_id %}" 
     hx-trigger="every 2s" 
     hx-swap="outerHTML"
     {% endif %}
     class="mt-4 p-4 border rounded-md bg-blue-50 border-blue-200">
    
    <div class="flex items-center space-x-3">
        {% if state == 'PENDING' %}
        <svg class="animate-spin h-5 w-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        {% else %}
        <span>✔️</span>
        {% endif %}
        <div>
            <p class="text-sm font-semibold text-blue-800">
                {% if state == 'PENDING' %}
                    Iniciando importación...
                {% elif state == 'PROGRESS' %}
                    Importando registros: {{ current_count }} procesados.
                {% elif state == 'SUCCESS' %}
                    ¡Importación completada! Se importaron {{ result.imported }} contribuyentes.
                {% elif state == 'FAILURE' %}
                    Error en la importación: {{ result }}
                {% else %}
                    Estado: {{ state }}
                {% endif %}
            </p>
            
            {% if state != 'SUCCESS' and state != 'FAILURE' %}
            <p class="text-xs text-blue-600 mt-1 italic">
                No cierre esta ventana hasta que el proceso finalice.
            </p>
            {% endif %}
        </div>
    </div>
</div>
