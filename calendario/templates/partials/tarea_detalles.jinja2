<form hx-post="/api/tarea/{{ tarea.id }}/" hx-target="body" class="space-y-4">
    {% csrf_token %}
    <div class="p-3 bg-blue-50 border border-blue-100 rounded-md mb-4 flex justify-between items-center">
        <div>
            <p class="text-xs text-blue-700 font-medium uppercase tracking-wider">Tarea: #{{ tarea.id }}</p>
            <p
                class="text-sm font-bold {% if tarea.estado == 'PENDIENTE' %}text-orange-500{% else %}text-green-500{% endif %}">
                {{ tarea.get_estado_display }}
            </p>
        </div>
        <button type="button" hx-post="/api/tarea/{{ tarea.id }}/toggle/" hx-target="body"
            class="px-3 py-1 text-xs font-semibold rounded-full border {% if tarea.estado == 'PENDIENTE' %}bg-green-100 text-green-700 border-green-200 hover:bg-green-200{% else %}bg-orange-100 text-orange-700 border-orange-200 hover:bg-orange-200{% endif %} transition">
            {% if tarea.estado == 'PENDIENTE' %}Marcar Completada{% else %}Marcar Pendiente{% endif %}
        </button>
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Título</label>
        <input type="text" name="titulo" value="{{ tarea.titulo }}"
            class="w-full py-1.5 bg-white px-4 text-sm border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#758bfd]"
            required>
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Estado</label>
        <select name="estado"
            class="w-full py-1.5 bg-white px-4 text-sm border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#758bfd]">
            {% for code, label in tarea.ESTADO_CHOICES %}
            <option value="{{ code }}" {% if tarea.estado == code %} selected {% endif %}>{{ label }}</option>
            {% endfor %}
        </select>
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Descripción</label>
        <textarea name="descripcion" rows="3"
            class="w-full py-1.5 bg-white px-4 text-sm border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#758bfd]">{{ tarea.descripcion }}</textarea>
    </div>

    <div class="grid grid-cols-2 gap-4">
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Fecha Inicio</label>
            <input type="datetime-local" name="fecha_inicio" value="{{ tarea.fecha_inicio|date:'Y-m-d\TH:i' }}"
                class="w-full py-1.5 bg-white px-4 text-sm border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#758bfd]"
                required>
        </div>
        <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Fecha Fin</label>
            <input type="datetime-local" name="fecha_fin" value="{{ tarea.fecha_fin|date:'Y-m-d\TH:i' }}"
                class="w-full py-1.5 bg-white px-4 text-sm border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#758bfd]"
                required>
        </div>
    </div>

    <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Asignar a Contacto</label>
        <select name="contacto"
            class="w-full py-1.5 bg-white px-4 text-sm border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-[#758bfd]">
            {% for contacto in contactos %}
            <option value="{{contacto.id}}" {% if tarea.contacto.id == contacto.id %}selected{% endif %}>
                {{ contacto.nombre }} {{ contacto.apellido }} ({{ contacto.empresa.nombre }}) ☎️ +{{ contacto.telefono }}
            </option>
            {% endfor %}
        </select>
    </div>

    <div class="pt-6 border-t flex flex-col gap-2">
        <button type="submit"
            class="w-full px-4 py-2 bg-[#758bfd] text-white rounded-md font-medium hover:bg-[#5a74e0] transition">
            Actualizar Tarea
        </button>
        <button type="button" hx-post="/api/tarea/{{ tarea.id }}/delete/"
            hx-confirm="¿Estás seguro de que deseas eliminar esta tarea?" hx-target="body"
            class="w-full px-4 py-2 text-red-500 hover:text-red-700 text-sm font-medium transition">
            Eliminar Tarea
        </button>
    </div>
</form>